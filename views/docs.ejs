                <tr><td><strong style="color:#E0C068;">Earth</strong></td><td>Fire, Electric, Machine</td><td>Water, Nature</td></tr>
                <tr><td><strong style="color:#81C4E8;">Wind</strong></td><td>Nature, Earth</td><td>Machine, Electric</td></tr>
                <tr><td><strong style="color:#B8B8D0;">Machine</strong></td><td>Nature, Wind</td><td>Fire, Water, Electric, Machine</td></tr>
                <tr><td><strong style="color:#FFD700;">Light</strong></td><td>Dark, Virus</td><td>Light</td></tr>
                <tr><td><strong style="color:#705898;">Dark</strong></td><td>Light</td><td>Holy Dragon, Holy Beast</td></tr>
                <tr><td><strong style="color:#A040A0;">Virus</strong></td><td>Light, Nature</td><td>Dark, Virus</td></tr>
