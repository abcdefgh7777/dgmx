<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DGMX - Documentation | Digital Monster On X</title>
    <link rel="icon" type="image/png" href="/fav.png">
    <link rel="stylesheet" href="/digivice-theme.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #0a0e1a;
            color: #e0e6f0;
            font-family: 'Share Tech Mono', 'Courier New', monospace;
            font-size: 14px;
            line-height: 1.7;
            min-height: 100vh;
        }

        /* ── Hero ── */
        .hero {
            background: linear-gradient(135deg, #0d1117 0%, #161b28 50%, #0d1117 100%);
            border-bottom: 2px solid #ff6600;
            padding: 28px 20px 32px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 0%, rgba(255,102,0,0.08) 0%, transparent 70%);
            pointer-events: none;
        }
        .hero-title {
            font-family: 'Orbitron', monospace;
            font-size: clamp(24px, 4vw, 36px);
            font-weight: 900;
            background: linear-gradient(90deg, #ff6600, #ffcc00, #ff6600);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 4px;
        }
        .hero-sub {
            color: #00ccff;
            font-family: 'Orbitron', monospace;
            font-size: 13px;
            margin-top: 8px;
            letter-spacing: 3px;
            text-transform: uppercase;
        }
        .hero-tagline {
            color: #8899aa;
            margin-top: 16px;
            font-size: 14px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }
        .hero-digimon {
            display: flex;
            justify-content: center;
            gap: 18px;
            margin-top: 28px;
            flex-wrap: wrap;
        }
        .hero-digimon img {
            width: 64px;
            height: 64px;
            object-fit: contain;
            image-rendering: pixelated;
            filter: drop-shadow(0 0 8px rgba(255,102,0,0.4));
            animation: float 3s ease-in-out infinite;
        }
        .hero-digimon img:nth-child(2) { animation-delay: 0.5s; }
        .hero-digimon img:nth-child(3) { animation-delay: 1s; }
        .hero-digimon img:nth-child(4) { animation-delay: 1.5s; }
        .hero-digimon img:nth-child(5) { animation-delay: 2s; }
        @keyframes float {
            0%,100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        /* ── Nav ── */
        .docs-nav {
            background: #0d1117;
            border-bottom: 1px solid #1e2a3a;
            padding: 12px 20px;
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .docs-nav a {
            color: #8899aa;
            text-decoration: none;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 6px 14px;
            border-radius: 4px;
            transition: all 0.2s;
            font-family: 'Orbitron', monospace;
        }
        .docs-nav a:hover, .docs-nav a.active {
            color: #ff6600;
            background: rgba(255,102,0,0.1);
        }
        .docs-nav .nav-home {
            color: #00ccff;
            border: 1px solid #00ccff33;
        }
        .docs-nav .nav-home:hover {
            background: rgba(0,204,255,0.1);
            color: #00ccff;
        }

        /* ── Container ── */
        .docs-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 30px 20px 80px;
        }

        /* ── Section ── */
        .doc-section {
            margin-bottom: 48px;
        }
        .section-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid #1e2a3a;
        }
        .section-num {
            background: #ff6600;
            color: #fff;
            font-family: 'Orbitron', monospace;
            font-size: 12px;
            font-weight: 700;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            flex-shrink: 0;
        }
        .section-title {
            font-family: 'Orbitron', monospace;
            font-size: 18px;
            color: #ffffff;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .section-text {
            color: #8899aa;
            margin-bottom: 16px;
            font-size: 13px;
        }

        /* ── Cards ── */
        .info-card {
            background: #111827;
            border: 1px solid #1e2a3a;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 16px;
            position: relative;
            overflow: hidden;
        }
        .info-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }
        .info-card.orange::before { background: linear-gradient(90deg, #ff6600, #ffcc00); }
        .info-card.cyan::before { background: linear-gradient(90deg, #00ccff, #0088ff); }
        .info-card.green::before { background: linear-gradient(90deg, #00ff88, #00cc66); }
        .info-card.red::before { background: linear-gradient(90deg, #ff3366, #ff6644); }
        .info-card.purple::before { background: linear-gradient(90deg, #8833ff, #cc44ff); }

        .card-title {
            font-family: 'Orbitron', monospace;
            font-size: 13px;
            color: #ff6600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
        }
        .info-card.cyan .card-title { color: #00ccff; }
        .info-card.green .card-title { color: #00ff88; }
        .info-card.red .card-title { color: #ff3366; }
        .info-card.purple .card-title { color: #8833ff; }

        .card-text { color: #8899aa; font-size: 13px; line-height: 1.8; }
        .card-text strong { color: #e0e6f0; }
        .card-text code {
            background: #1a2332;
            color: #ffcc00;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-family: 'Share Tech Mono', monospace;
        }

        /* ── Command blocks ── */
        .cmd-block {
            background: #0d1117;
            border: 1px solid #1e2a3a;
            border-radius: 8px;
            margin-bottom: 12px;
            overflow: hidden;
        }
        .cmd-header {
            background: #161b28;
            padding: 10px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid #1e2a3a;
        }
        .cmd-name {
            font-family: 'Orbitron', monospace;
            font-size: 13px;
            color: #ffcc00;
            font-weight: 700;
        }
        .cmd-tag {
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .cmd-tag.core { background: #ff660033; color: #ff6600; }
        .cmd-tag.social { background: #00ccff33; color: #00ccff; }
        .cmd-tag.combat { background: #ff336633; color: #ff3366; }
        .cmd-body {
            padding: 14px 16px;
            color: #8899aa;
            font-size: 13px;
            line-height: 1.8;
        }
        .cmd-body strong { color: #e0e6f0; }
        .cmd-example {
            background: #0a0e1a;
            border: 1px solid #1e2a3a;
            border-radius: 6px;
            padding: 10px 14px;
            margin-top: 10px;
            color: #00ccff;
            font-size: 12px;
        }
        .cmd-example::before {
            content: 'EXAMPLE ';
            color: #334455;
            font-size: 10px;
            letter-spacing: 1px;
        }

        /* ── Evolution showcase ── */
        .evo-chain {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            flex-wrap: wrap;
            padding: 24px 16px;
            background: #0d1117;
            border: 1px solid #1e2a3a;
            border-radius: 10px;
            margin: 16px 0;
        }
        .evo-stage {
            text-align: center;
            min-width: 100px;
        }
        .evo-stage img {
            width: 56px;
            height: 56px;
            object-fit: contain;
            image-rendering: pixelated;
            filter: drop-shadow(0 0 6px rgba(0,204,255,0.3));
            margin-bottom: 6px;
        }
        .evo-label {
            font-family: 'Orbitron', monospace;
            font-size: 9px;
            color: #ff6600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .evo-name {
            color: #e0e6f0;
            font-size: 11px;
            margin-top: 2px;
        }
        .evo-arrow {
            color: #334455;
            font-size: 20px;
            font-weight: 700;
        }

        /* ── Type grid ── */
        .type-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            gap: 8px;
            margin: 16px 0;
        }
        .type-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-family: 'Orbitron', monospace;
        }

        /* ── Digimon showcase row ── */
        .digi-showcase {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
            margin: 20px 0;
        }
        .digi-card {
            text-align: center;
            background: #111827;
            border: 1px solid #1e2a3a;
            border-radius: 10px;
            padding: 16px;
            width: 120px;
        }
        .digi-card img {
            width: 64px;
            height: 64px;
            object-fit: contain;
            image-rendering: pixelated;
            filter: drop-shadow(0 0 6px rgba(0,204,255,0.3));
        }
        .digi-card .digi-name {
            color: #e0e6f0;
            font-size: 11px;
            margin-top: 8px;
            font-weight: 600;
        }
        .digi-card .digi-stage {
            color: #ff6600;
            font-size: 9px;
            font-family: 'Orbitron', monospace;
            text-transform: uppercase;
            margin-top: 4px;
        }

        /* ── Step flow ── */
        .step-flow {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            margin: 16px 0;
        }
        .step-item {
            flex: 1;
            min-width: 200px;
            background: #111827;
            border: 1px solid #1e2a3a;
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            position: relative;
        }
        .step-num {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, #ff6600, #ffcc00);
            color: #000;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Orbitron', monospace;
            font-weight: 900;
            font-size: 16px;
            margin: 0 auto 12px;
        }
        .step-title {
            color: #ffffff;
            font-family: 'Orbitron', monospace;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        .step-desc { color: #8899aa; font-size: 12px; }

        /* ── Table ── */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin: 16px 0;
            font-size: 13px;
        }
        .data-table th {
            background: #161b28;
            color: #ff6600;
            font-family: 'Orbitron', monospace;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 10px 14px;
            text-align: left;
            border-bottom: 2px solid #ff660044;
        }
        .data-table td {
            padding: 10px 14px;
            border-bottom: 1px solid #1e2a3a;
            color: #8899aa;
        }
        .data-table tr:hover td { background: #111827; }
        .data-table td code {
            background: #1a2332;
            color: #ffcc00;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 12px;
        }

        /* ── Badge / highlight ── */
        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 10px;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Orbitron', monospace;
            font-weight: 700;
        }
        .badge-orange { background: #ff660022; color: #ff6600; border: 1px solid #ff660044; }
        .badge-cyan { background: #00ccff22; color: #00ccff; border: 1px solid #00ccff44; }
        .badge-green { background: #00ff8822; color: #00ff88; border: 1px solid #00ff8844; }

        /* ── OpenClaw section ── */
        .openclaw-banner {
            background: linear-gradient(135deg, #0d1117, #1a1040, #0d1117);
            border: 1px solid #8833ff44;
            border-radius: 12px;
            padding: 30px;
            text-align: center;
            margin: 20px 0;
            position: relative;
            overflow: hidden;
        }
        .openclaw-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 0%, rgba(136,51,255,0.1) 0%, transparent 70%);
            pointer-events: none;
        }
        .openclaw-title {
            font-family: 'Orbitron', monospace;
            font-size: 20px;
            color: #cc44ff;
            letter-spacing: 3px;
            margin-bottom: 12px;
        }
        .openclaw-text {
            color: #8899aa;
            font-size: 13px;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.8;
        }

        /* ── Footer ── */
        .docs-footer {
            text-align: center;
            padding: 40px 20px;
            border-top: 1px solid #1e2a3a;
            margin-top: 40px;
        }
        .docs-footer a {
            color: #ff6600;
            text-decoration: none;
        }
        .docs-footer a:hover { color: #ffcc00; }

        /* ── Responsive ── */
        @media (max-width: 640px) {
            .evo-chain { gap: 4px; }
            .evo-stage { min-width: 70px; }
            .evo-stage img { width: 40px; height: 40px; }
            .step-flow { flex-direction: column; }
            .type-grid { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); }
        }
    </style>
</head>
<body>

