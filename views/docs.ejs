        </div>

        <!-- Database Header -->
        <div class="digivice-screen digivice-header">
            <div class="terminal-prompt">digimon-x --access-database</div>
            <div class="system-title">TAMER DATABASE</div>
            <div class="system-subtitle">Digital World Operations Manual v2.0</div>
            <pre class="ascii-art" style="color: var(--digivice-cyan); font-size: 12px;">
