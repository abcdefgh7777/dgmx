    <!-- ── 3. EVOLUTION SYSTEM ── -->
    <div class="doc-section" id="evolution">
        <div class="section-header">
            <div class="section-num">3</div>
            <div class="section-title">Evolution System</div>
        </div>
        <p class="section-text">
            Digimon evolve through 5 stages. Each stage unlocks a more powerful form with higher stats.
            Your Digimon must reach <strong>Level 5</strong> before it can digivolve to the next stage.
        </p>

        <!-- Evolution chain showcase -->
        <div class="evo-chain">
            <div class="evo-stage">
                <img src="/digimon/baby/Botamon.gif" alt="Botamon">
                <div class="evo-label">Baby</div>
                <div class="evo-name">Botamon</div>
            </div>
            <div class="evo-arrow">&rarr;</div>
            <div class="evo-stage">
                <img src="/digimon/child/Agumon.gif" alt="Agumon">
                <div class="evo-label">Rookie</div>
                <div class="evo-name">Agumon</div>
            </div>
            <div class="evo-arrow">&rarr;</div>
            <div class="evo-stage">
                <img src="/digimon/adult/Greymon.gif" alt="Greymon">
                <div class="evo-label">Champion</div>
                <div class="evo-name">Greymon</div>
            </div>
            <div class="evo-arrow">&rarr;</div>
            <div class="evo-stage">
                <img src="/digimon/perfect/MetalGreymon.gif" alt="MetalGreymon">
                <div class="evo-label">Ultimate</div>
                <div class="evo-name">MetalGreymon</div>
            </div>
            <div class="evo-arrow">&rarr;</div>
            <div class="evo-stage">
                <img src="/digimon/ultimate/WarGreymon.gif" alt="WarGreymon">
                <div class="evo-label">Mega</div>
                <div class="evo-name">WarGreymon</div>
            </div>
        </div>

        <div class="info-card orange">
            <div class="card-title">How Evolution Works</div>
            <div class="card-text">
                <strong>1.</strong> Feed and battle your Digimon to earn XP and level up.<br>
                <strong>2.</strong> When your Digimon reaches <strong>Level 5+</strong>, use the <code>digivolve</code> command.<br>
                <strong>3.</strong> Your Digimon transforms into a random evolution from its evolution tree.<br>
                <strong>4.</strong> Level resets to 1, but your new form has <strong>much stronger base stats</strong>.<br>
                <strong>5.</strong> Multiple evolution paths exist &mdash; the same Digimon can evolve into different forms!
            </div>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Stage</th>
                    <th>Power Level</th>
                    <th>Requirement</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong style="color:#00ccff;">Baby</strong></td>
                    <td>Weakest &mdash; newly hatched</td>
                    <td>Starting stage (use <code>tame</code>)</td>
                </tr>
                <tr>
                    <td><strong style="color:#00ff88;">Rookie</strong></td>
                    <td>Basic combat ready</td>
                    <td>Digivolve at Lv.5</td>
                </tr>
                <tr>
                    <td><strong style="color:#ffcc00;">Champion</strong></td>
                    <td>Strong fighter</td>
                    <td>Digivolve at Lv.5</td>
                </tr>
                <tr>
                    <td><strong style="color:#ff6600;">Ultimate</strong></td>
                    <td>Very powerful</td>
                    <td>Digivolve at Lv.5</td>
                </tr>
                <tr>
                    <td><strong style="color:#ff3366;">Mega</strong></td>
                    <td>Maximum power</td>
                    <td>Digivolve at Lv.5 (final form)</td>
                </tr>
            </tbody>
        </table>

        <!-- Digimon showcase per stage -->
        <p class="section-text" style="margin-top:24px;">Some Digimon you might encounter at each stage:</p>
        <div class="digi-showcase">
            <div class="digi-card">
                <img src="/digimon/baby/Poyomon.gif" alt="Poyomon">
                <div class="digi-name">Poyomon</div>
                <div class="digi-stage">Baby</div>
            </div>
            <div class="digi-card">
                <img src="/digimon/child/Gomamon.gif" alt="Gomamon">
                <div class="digi-name">Gomamon</div>
                <div class="digi-stage">Rookie</div>
            </div>
            <div class="digi-card">
                <img src="/digimon/adult/Angemon.gif" alt="Angemon">
                <div class="digi-name">Angemon</div>
                <div class="digi-stage">Champion</div>
            </div>
            <div class="digi-card">
                <img src="/digimon/perfect/Angewomon.gif" alt="Angewomon">
                <div class="digi-name">Angewomon</div>
                <div class="digi-stage">Ultimate</div>
            </div>
            <div class="digi-card">
                <img src="/digimon/ultimate/Alphamon.gif" alt="Alphamon">
