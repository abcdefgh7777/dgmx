    <title>Digimon X Documentation - Digital Monster Collection Guide</title>
    <link rel="icon" type="image/png" href="/fav.png">
    <!-- Digivice Theme CSS -->
    <link rel="stylesheet" href="/digivice-theme.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: var(--bg-primary);
            color: var(--digivice-cyan);
            font-family: 'Share Tech Mono', 'Courier New', monospace;
            font-size: 14px;
            line-height: 1.6;
            min-height: 100vh;
            padding: 1rem;
            image-rendering: pixelated;
            font-smooth: never;
            -webkit-font-smoothing: none;
            overflow-x: auto;
        }
        
        .terminal-container {
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .nav-terminal {
            padding: 15px;
            margin-bottom: 20px;
        }
        
        .nav-links {
            display: flex;
            gap: 20px;
            align-items: center;
        }
        
        .nav-link {
            color: var(--digivice-white);
            text-decoration: none;
            padding: 8px 15px;
            background: var(--digivice-orange);
            text-transform: uppercase;
            font-family: 'Orbitron', monospace;
            border: none;
            margin: 0 5px;
            display: inline-block;
            box-shadow: -2px -2px 0 #2a5930 inset, 2px 2px 0 #6ac77a inset;
        }
        
        .nav-link:hover {
            background: #6ac77a;
            transform: scale(1.05);
        }
        
        .terminal-title {
            color: var(--digivice-cyan);
            font-size: 14px;
            text-transform: uppercase;
            font-family: 'Orbitron', monospace;
        }
        
        .prompt::before {
            content: '$ ';
            color: #ffffff;
        }
        
        .doc-header {
            padding: 20px;
            margin-bottom: 30px;
            text-align: center;
        }
        
        .doc-section {
            margin-bottom: 20px;
            padding: 20px;
        }
        
        .section-title {
            color: var(--digivice-orange);
            font-size: 16px;
            text-transform: uppercase;
            margin-bottom: 15px;
            border-bottom: 1px solid var(--digivice-orange);
            padding-bottom: 10px;
            font-family: 'Orbitron', monospace;
        }
        
        .command {
            background: var(--bg-card);
            padding: 15px;
            margin: 10px 0;
            border: 1px solid var(--digivice-cyan);
            border-radius: 8px;
            font-family: 'Share Tech Mono', monospace;
            text-transform: uppercase;
        }
        
        .command-name {
            color: var(--digivice-orange);
            font-weight: bold;
            text-transform: uppercase;
            font-size: 14px;
            margin-bottom: 8px;
        }
        
        .warning {
            background: var(--bg-card);
            border: 1px solid var(--digivice-red);
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
            color: var(--digivice-red);
            text-transform: uppercase;
        }
        
        .info {
            background: var(--bg-card);
            border: 1px solid var(--digivice-green);
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
            color: var(--digivice-green);
            text-transform: uppercase;
        }
        
        .success {
            background: var(--bg-card);
            border: 1px solid var(--digivice-green);
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
            color: var(--digivice-green);
            text-transform: uppercase;
        }
        
        .code-block {
            background: var(--bg-terminal);
            border: 1px solid var(--digivice-cyan);
            border-radius: 8px;
            padding: 15px;
            margin: 10px 0;
            overflow-x: auto;
            font-family: 'Share Tech Mono', monospace;
            font-size: 12px;
            color: var(--digivice-cyan);
        }
        
        .toc {
            background: var(--bg-card);
            border: 1px solid var(--digivice-orange);
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 30px;
        }
        
        .toc ul {
            list-style: none;
            padding-left: 20px;
        }
        
        .toc a {
            color: var(--digivice-cyan);
            text-decoration: none;
            text-transform: uppercase;
            font-size: 12px;
        }
        
        .toc a:hover {
            color: var(--digivice-orange);
        }
        
        .ascii-art {
            color: var(--digivice-green);
            text-align: center;
            font-size: 12px;
            line-height: 1.4;
            margin: 20px 0;
            font-family: 'Share Tech Mono', monospace;
        }
        
        .highlight {
            color: var(--digivice-red);
            font-weight: bold;
            text-transform: uppercase;
        }
        
        .x-handle {
            color: var(--digivice-orange);
            text-decoration: none;
            text-transform: uppercase;
        }
        
        .x-handle:hover {
            color: var(--digivice-yellow);
        }
    </style>
</head>
<body>
    <div class="digivice-container">
