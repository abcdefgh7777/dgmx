        <!-- Table of Contents -->
        <div class="toc framed no-hd">
            <div class="section-title">Table of Contents</div>
            <ul>
                <li><a href="#quick-start">1. Quick Start Guide</a></li>
                <li><a href="#catching">2. Digimon Capture System</a></li>
                <li><a href="#commands">3. Command Reference</a></li>
