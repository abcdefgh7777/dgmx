            <div class="type-chip" style="background:#B8B8D088;border:1px solid #B8B8D0;color:#000;">Machine</div>
            <div class="type-chip" style="background:#FFD70088;border:1px solid #FFD700;color:#000;">Light</div>
            <div class="type-chip" style="background:#70589888;border:1px solid #705898;">Dark</div>
            <div class="type-chip" style="background:#A040A088;border:1px solid #A040A0;">Virus</div>
            <div class="type-chip" style="background:#7038F888;border:1px solid #7038F8;">Dragon</div>
            <div class="type-chip" style="background:#7038F866;border:1px solid #9060FF;">Holy Dragon</div>
            <div class="type-chip" style="background:#A890F088;border:1px solid #A890F0;">Holy Beast</div>
        </div>

        <div class="info-card orange">
            <div class="card-title">Type Advantage Chart</div>
            <div class="card-text">
                <strong style="color:#00ff88;">Super Effective (2x damage):</strong>
            </div>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Attacker</th>
                    <th>Strong Against (2x)</th>
                    <th>Weak Against (0.5x)</th>
