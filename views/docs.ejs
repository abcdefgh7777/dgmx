        </div>

        <!-- Footer -->
        <div class="framed no-hd" style="margin-top: 40px; text-align: center;">
            <div style="color: var(--digivice-green); font-size: 12px; text-transform: uppercase;">
                Digimon X Documentation v1.0.0 | Digital Monsters Are The Champions!<br>
                Built by Digimon Tamers<br>
                <a href="https://x.com/digimononx" class="x-handle">@digimononx</a>
