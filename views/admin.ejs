<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - Digimon X Digital Monster Manager</title>
    <link rel="icon" type="image/png" href="/fav.png">
    <!-- Digimon Digital Theme CSS -->
    <link rel="stylesheet" href="/digivice-theme.css">
    <style>
        body {
            background: #F8F3F8;
            min-height: 100vh;
            font-family: 'Pokemon GB', 'Courier New', monospace;
            font-size: 12px;
            padding: 2em;
            color: #181010;
            image-rendering: pixelated;
            font-smooth: never;
            -webkit-font-smoothing: none;
        }
        .container {
            max-width: 1200px;
        }
        .admin-card {
            margin-bottom: 20px;
        }
        .pet-card {
            background: white;
            border: 3px solid #181010;
            padding: 15px;
            margin-bottom: 15px;
        }
        .ascii-art {
            font-family: 'Pixel Digivolve', 'PixelMplus12', monospace;
            line-height: 1.4;
            color: #48A058;
            font-size: 10px;
        }
        .header-title {
            text-transform: uppercase;
            font-family: 'Pixel Digivolve', 'PixelMplus12', monospace;
            color: #181010;
            font-size: 20px;
            margin-bottom: 10px;
        }
        .tab-button {
            background: #48A058;
            color: #F8F3F8;
            text-transform: uppercase;
            font-family: 'Pixel Digivolve', 'PixelMplus12', monospace;
            padding: 10px 20px;
            border: none;
            margin: 5px;
            cursor: pointer;
            font-size: 11px;
            box-shadow: inset -2px -2px 0 #2a5930, inset 2px 2px 0 #6ac77a;
        }
        .tab-button:hover {
            background: #6ac77a;
            transform: scale(1.05);
        }
        .tab-button.active {
            background: #F0B088;
            box-shadow: inset -2px -2px 0 #d09060, inset 2px 2px 0 #ffd0a8;
        }
        .modal {
            background: rgba(24, 16, 16, 0.9);
        }
        .btn-primary {
            background: #48A058;
            color: #F8F3F8;
            padding: 8px 16px;
            border: none;
            text-transform: uppercase;
            font-family: 'Pixel Digivolve', 'PixelMplus12', monospace;
            cursor: pointer;
            font-size: 10px;
            box-shadow: inset -2px -2px 0 #2a5930, inset 2px 2px 0 #6ac77a;
        }
        .btn-primary:hover {
            background: #6ac77a;
        }
        .btn-danger {
            background: #B3181C;
            color: #F8F3F8;
            padding: 8px 16px;
            border: none;
            text-transform: uppercase;
            font-family: 'Pixel Digivolve', 'PixelMplus12', monospace;
            cursor: pointer;
            font-size: 10px;
            box-shadow: inset -2px -2px 0 #851014, inset 2px 2px 0 #d53034;
        }
        .btn-danger:hover {
            background: #d53034;
        }
        .btn-secondary {
            background: #F0B088;
            color: #181010;
            padding: 8px 16px;
            border: none;
            text-transform: uppercase;
            font-family: 'Pixel Digivolve', 'PixelMplus12', monospace;
            cursor: pointer;
            font-size: 10px;
            box-shadow: inset -2px -2px 0 #d09060, inset 2px 2px 0 #ffd0a8;
        }
        .btn-secondary:hover {
            background: #ffd0a8;
        }
        input, textarea, select {
            background: white;
            border: 3px solid #181010;
            padding: 8px;
            font-family: 'Pixel Digivolve', 'PixelMplus12', monospace;
            font-size: 10px;
            color: #181010;
            width: 100%;
            text-transform: uppercase;
        }
        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #48A058;
            box-shadow: 0 0 0 2px #48A058;
        }
        label {
            text-transform: uppercase;
            font-size: 10px;
            margin-bottom: 5px;
            display: block;
            color: #181010;
        }
        .grid-cols-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }
        .text-center { text-align: center; }
        .mb-2 { margin-bottom: 8px; }
        .mb-3 { margin-bottom: 12px; }
        .mb-4 { margin-bottom: 16px; }
        .mb-6 { margin-bottom: 24px; }
        .mb-8 { margin-bottom: 32px; }
        .px-2 { padding-left: 8px; padding-right: 8px; }
        .py-1 { padding-top: 4px; padding-bottom: 4px; }
        .px-4 { padding-left: 16px; padding-right: 16px; }
        .py-2 { padding-top: 8px; padding-bottom: 8px; }
        .rounded { border-radius: 4px; }
        .rounded-lg { border-radius: 8px; }
        .text-xs { font-size: 9px; }
        .text-sm { font-size: 10px; }
        .text-2xl { font-size: 16px; }
        .text-4xl { font-size: 20px; }
        .font-bold { font-weight: normal; }
        .flex { display: flex; }
        .justify-center { justify-content: center; }
        .space-x-4 > * + * { margin-left: 16px; }
        .gap-2 { gap: 8px; }
        .flex-wrap { flex-wrap: wrap; }
        .hidden { display: none; }
        .block { display: block; }
        .inline-block { display: inline-block; }
        .w-full { width: 100%; }
        .mx-auto { margin-left: auto; margin-right: auto; }
    </style>
</head>
<body>
    <div class="container wrapper mx-auto">
        <header class="framed primary text-center mb-8">
            <h1 class="header-title">Tamer Admin Panel</h1>
            <p class="text-sm mb-4">Manage your Digimon collection</p>
            <div class="flex justify-center space-x-4">
                <a href="/" class="btn-secondary inline-block">
                    Home
                </a>
                <a href="/admin/logout" class="btn-danger inline-block">
                    Logout
                </a>
            </div>
        </header>

        <!-- Tab Navigation -->
        <div class="admin-card framed neutral mb-6">
            <div class="flex flex-wrap gap-2 justify-center mb-6">
                <button onclick="showTab('pets')" class="tab-button active" id="pets-tab">
                    Manage Digimon
                </button>
                <button onclick="showTab('add-pet')" class="tab-button" id="add-pet-tab">
                    Add Digimon
                </button>
                <button onclick="showTab('templates')" class="tab-button" id="templates-tab">
                    Templates
                </button>
                <button onclick="showTab('ai-generate')" class="tab-button" id="ai-generate-tab">
                    Capture Digimon
                </button>
                <button onclick="showTab('x-agent')" class="tab-button" id="x-agent-tab">
                    X Agent
                </button>
            </div>

            <!-- Manage Pets Tab -->
            <div id="pets-content" class="tab-content">
                <h2 class="text-2xl font-bold mb-4">Your Digimon Collection</h2>
                <% if (pets && pets.length > 0) { %>
                    <div class="grid-cols-3">
                        <% pets.forEach(pet => { %>
                            <div class="pet-card framed no-hd">
                                <div class="text-center mb-3">
                                    <% if (pet.ascii && pet.ascii.startsWith('/digimon/')) { %>
                                        <!-- Display Digimon GIF -->
                                        <div class="framed no-hd mb-2" style="height: 100px; display: flex; align-items: center; justify-content: center; background: white;">
                                            <img src="<%= pet.ascii %>" alt="<%= pet.name %>" style="max-width: 100%; max-height: 80px; object-fit: contain;" />
                                        </div>
                                    <% } else { %>
                                        <!-- Fallback to ASCII for old entries -->
                                        <pre class="ascii-art text-xs framed no-hd mb-2" style="background: white; padding: 10px;"><%= pet.ascii %></pre>
                                    <% } %>
                                    <h3 class="font-bold" style="color: #181010; text-transform: uppercase;"><%= pet.name %></h3>
                                    <p class="text-sm" style="color: #48A058; text-transform: uppercase;"><%= pet.race %></p>
                                    <p class="text-xs" style="color: #B3181C; text-transform: uppercase;"><%= pet.ownerHandle %></p>
                                </div>
                                
                                <div class="text-center text-sm mb-3">
                                    <span class="px-2 py-1 text-xs" style="background: #48A058; color: #F8F3F8; text-transform: uppercase;"><%= pet.status %></span>
                                    <span class="px-2 py-1 text-xs" style="background: #F0B088; color: #181010; margin-left: 4px; text-transform: uppercase;">
                                        <% if (pet.growth_stage === 'Baby') { %>B<% } %>
                                        <% if (pet.growth_stage === 'Teen') { %>T<% } %>
                                        <% if (pet.growth_stage === 'Adult') { %>A<% } %>
                                        <%= pet.growth_stage %>
                                    </span>
                                    <div style="margin-top: 4px;">
                                        <span class="text-xs" style="color: #48A058; text-transform: uppercase;">Fed <%= pet.feed_count %> times</span>
                                    </div>
                                </div>
                                
                                <div class="flex gap-2 justify-center">
                                    <button onclick="feedPet(<%= pet.id %>)" class="btn-primary text-xs">
                                        Feed
                                    </button>
                                    <button onclick="generateStatusCard(<%= pet.id %>)" class="btn-secondary text-xs">
                                        Status
                                    </button>
                                    <button onclick="editPet(<%= pet.id %>)" class="btn-primary text-xs">
                                        Edit
                                    </button>
                                    <button onclick="deletePet(<%= pet.id %>)" class="btn-danger text-xs">
                                        Delete
                                    </button>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="text-center py-8">
                        <p class="text-slate-400">No Digimon yet. Start capturing!</p>
                    </div>
                <% } %>
            </div>

            <!-- Add Pet Tab -->
            <div id="add-pet-content" class="tab-content hidden">
                <h2 class="text-2xl font-bold mb-4">➕ Add New Digimon</h2>
                <form id="add-pet-form" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium mb-2">ASCII Art</label>
                            <textarea id="pet-ascii" rows="8" class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white font-mono text-sm" placeholder="Paste ASCII art here..."></textarea>
                        </div>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium mb-2">Name</label>
                                <input type="text" id="pet-name" class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white">
                            </div>
                            <div>
                                <label class="block text-sm font-medium mb-2">Type</label>
                                <input type="text" id="pet-race" class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white">
                            </div>
                            <div>
                                <label class="block text-sm font-medium mb-2">Owner X Link</label>
                                <input type="url" id="pet-owner" class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white" placeholder="https://x.com/username">
                            </div>
                            <div>
                                <label class="block text-sm font-medium mb-2">Status</label>
                                <select id="pet-status" class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white">
                                    <option value="Happy">😊 Happy</option>
                                    <option value="Sleepy">😴 Sleepy</option>
                                    <option value="Excited">🤩 Excited</option>
                                    <option value="Calm">😌 Calm</option>
                                    <option value="Playful">🎮 Playful</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <button type="submit" class="w-full bg-green-600 hover:bg-green-700 px-6 py-3 rounded-lg font-medium transition duration-300">
                        🎉 Add Digimon
                    </button>
                </form>
            </div>

            <!-- Templates Tab -->
            <div id="templates-content" class="tab-content hidden">
                <h2 class="text-2xl font-bold mb-4">📝 ASCII Templates</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <% templates.forEach(template => { %>
                        <div class="pet-card rounded-lg p-4">
                            <div class="text-center mb-3">
                                <pre class="ascii-art text-xs bg-gray-900 p-3 rounded mb-2"><%= template.ascii %></pre>
                                <h3 class="font-bold text-white"><%= template.name %></h3>
                                <p class="text-cyan-300 text-sm"><%= template.race %></p>
                            </div>
                            <button onclick="useTemplate(<%= template.id %>)" class="w-full bg-purple-600 hover:bg-purple-700 px-3 py-2 rounded text-sm transition duration-300">
                                🎯 Use Template
                            </button>
                        </div>
                    <% }); %>
                </div>
            </div>

            <!-- AI Generate Tab -->
            <div id="ai-generate-content" class="tab-content hidden">
                <h2 class="text-2xl font-bold mb-4">⚡ Capture Wild Digimon</h2>
                <div class="max-w-2xl mx-auto">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium mb-2">Owner X Link</label>
                            <input type="url" id="ai-owner" class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white" placeholder="https://x.com/username">
                        </div>
                        <button onclick="captureDigimon()" class="w-full bg-purple-600 hover:bg-purple-700 px-6 py-3 rounded-lg font-medium transition duration-300">
                            ⚡ Enter Digital World!
                        </button>
                    </div>
                    
                    <div id="ai-preview" class="hidden mt-6 p-4 bg-gray-800 rounded-lg">
                        <h3 class="text-lg font-bold mb-3">🔍 Captured Digimon Preview</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <div id="ai-gif-container" class="bg-gray-900 p-3 rounded text-center" style="height: 120px; display: none; align-items: center; justify-content: center;">
                                    <img id="ai-gif" style="max-width: 100%; max-height: 100px; object-fit: contain;" />
                                </div>
                                <pre id="ai-ascii" class="ascii-art text-xs bg-gray-900 p-3 rounded"></pre>
                            </div>
                            <div class="space-y-2">
                                <p><strong>Name:</strong> <span id="ai-name"></span></p>
                                <p><strong>Type:</strong> <span id="ai-race"></span></p>
                                <p><strong>Trainer:</strong> <span id="ai-owner-display"></span></p>
                            </div>
                        </div>
                        <div class="mt-4 flex gap-2">
                            <button onclick="acceptGenerated()" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded transition duration-300">
                                ✅ Accept & Add Pet
                            </button>
                            <button onclick="generateSocialCard()" class="bg-purple-600 hover:bg-purple-700 px-4 py-2 rounded transition duration-300">
                                📱 Generate Social Card
                            </button>
                            <button onclick="generatePet()" class="bg-yellow-600 hover:bg-yellow-700 px-4 py-2 rounded transition duration-300">
                                🔄 Generate Another
                            </button>
                            <button onclick="hidePreview()" class="bg-gray-600 hover:bg-gray-700 px-4 py-2 rounded transition duration-300">
                                ❌ Cancel
                            </button>
                        </div>
                    </div>
                    
                    <!-- Social Media Card Generator -->
                    <div id="social-card-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50">
                        <div class="flex items-center justify-center min-h-screen p-4">
                            <div class="bg-gray-800 rounded-lg p-6 max-w-lg w-full">
                                <h3 class="text-xl font-bold mb-4">📱 DIGIMON X Capture Card</h3>
                                
                                <div class="mb-4">
                                    <canvas id="social-canvas" width="800" height="600" style="max-width: 100%; border: 1px solid #666;"></canvas>
                                </div>
                                
                                <div class="flex gap-2">
                                    <button onclick="downloadSocialCard()" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded transition duration-300">
                                        💾 Download Image
                                    </button>
                                    <button onclick="copySocialCard()" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded transition duration-300">
                                        📋 Copy to Clipboard
                                    </button>
                                    <button onclick="closeSocialCard()" class="bg-gray-600 hover:bg-gray-700 px-4 py-2 rounded transition duration-300">
                                        ❌ Close
                                    </button>
                                </div>
                                
                                <div class="mt-4 p-3 bg-gray-700 rounded text-sm">
                                    <p class="text-green-400">💡 Tip: Download the image and share it on X/Twitter!</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- X Agent Tab -->
            <div id="x-agent-content" class="tab-content hidden">
                <h2 style="font-size:16px; margin-bottom:15px; text-transform:uppercase; font-family:'Pokemon GB',monospace;">X Agent Control Panel</h2>

                <!-- Agent Status -->
                <div style="background:#181010; border:3px solid #48A058; padding:15px; margin-bottom:15px;">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                        <span style="color:#48A058; font-size:11px;">AGENT STATUS</span>
                        <span id="agent-status-badge" style="padding:3px 10px; font-size:10px; background:#B3181C; color:#F8F3F8;">OFFLINE</span>
                    </div>
                    <div style="color:#F8F3F8; font-size:10px; line-height:2;">
                        <div>Bot: @<span id="agent-bot-name">digimononx</span></div>
                        <div>Replies Today: <span id="agent-replies-today">0</span></div>
                        <div>Total Replies: <span id="agent-replies-total">0</span></div>
                        <div>Last Checked: <span id="agent-last-checked">never</span></div>
                        <div>Last Error: <span id="agent-last-error" style="color:#B3181C;">none</span></div>
                    </div>
                    <div style="margin-top:10px; display:flex; gap:8px; flex-wrap:wrap;">
                        <button onclick="startAgent()" class="btn-primary" style="font-size:9px;">START AGENT</button>
                        <button onclick="stopAgent()" class="btn-danger" style="font-size:9px;">STOP AGENT</button>
                        <button onclick="refreshAgentStatus()" class="btn-secondary" style="font-size:9px;">REFRESH</button>
                        <button onclick="clearReplies()" class="btn-secondary" style="font-size:9px;">CLEAR LOGS</button>
                        <button onclick="clearFailed()" class="btn-secondary" style="font-size:9px;">RETRY FAILED</button>
                        <button onclick="backfillAvatars()" class="btn-secondary" style="font-size:9px;">BACKFILL AVATARS</button>
                    </div>
                </div>

                <!-- Test Agent Reply -->
                <div style="background:#181010; border:3px solid #F0B088; padding:15px; margin-bottom:15px;">
                    <div style="color:#F0B088; font-size:11px; margin-bottom:10px;">TEST AGENT REPLY (PREVIEW BEFORE POSTING)</div>
                    <div style="color:#888; font-size:9px; margin-bottom:8px;">Simulate a mention to see how the agent would reply. Nothing is posted to X.</div>
                    <div style="display:flex; gap:8px; margin-bottom:10px; flex-wrap:wrap;">
                        <input type="text" id="test-username" placeholder="@username" value="testuser"
                               style="background:#222; border:2px solid #F0B088; color:#F8F3F8; padding:6px 10px; font-family:'Pokemon GB',monospace; font-size:10px; width:120px;">
                        <input type="text" id="test-message" placeholder="Type a command... (tame, check, feed, battle, digivolve)"
                               style="background:#222; border:2px solid #F0B088; color:#F8F3F8; padding:6px 10px; font-family:'Pokemon GB',monospace; font-size:10px; flex:1; min-width:200px;">
                        <button onclick="testAgentReply()" class="btn-primary" style="font-size:9px; background:#F0B088; color:#181010;">TEST REPLY</button>
                    </div>
                    <div style="display:flex; gap:5px; flex-wrap:wrap; margin-bottom:10px;">
                        <button onclick="quickTest('tame digimon')" style="background:#333;color:#48A058;border:1px solid #48A058;padding:3px 8px;font-size:9px;cursor:pointer;font-family:'Pokemon GB',monospace;">tame</button>
                        <button onclick="quickTest('check my digimon')" style="background:#333;color:#48A058;border:1px solid #48A058;padding:3px 8px;font-size:9px;cursor:pointer;font-family:'Pokemon GB',monospace;">check</button>
                        <button onclick="quickTest('feed my first digimon')" style="background:#333;color:#48A058;border:1px solid #48A058;padding:3px 8px;font-size:9px;cursor:pointer;font-family:'Pokemon GB',monospace;">feed</button>
                        <button onclick="quickTest('battle someone')" style="background:#333;color:#48A058;border:1px solid #48A058;padding:3px 8px;font-size:9px;cursor:pointer;font-family:'Pokemon GB',monospace;">battle</button>
                        <button onclick="quickTest('digivolve my digimon')" style="background:#333;color:#48A058;border:1px solid #48A058;padding:3px 8px;font-size:9px;cursor:pointer;font-family:'Pokemon GB',monospace;">digivolve</button>
                        <button onclick="quickTest('format device')" style="background:#333;color:#48A058;border:1px solid #48A058;padding:3px 8px;font-size:9px;cursor:pointer;font-family:'Pokemon GB',monospace;">format</button>
                        <button onclick="quickTest('help')" style="background:#333;color:#48A058;border:1px solid #48A058;padding:3px 8px;font-size:9px;cursor:pointer;font-family:'Pokemon GB',monospace;">help</button>
                        <button onclick="quickTest('take my agumon for a walk')" style="background:#333;color:#48A058;border:1px solid #48A058;padding:3px 8px;font-size:9px;cursor:pointer;font-family:'Pokemon GB',monospace;">activity</button>
                        <button onclick="quickTest('hello how does this work?')" style="background:#333;color:#48A058;border:1px solid #48A058;padding:3px 8px;font-size:9px;cursor:pointer;font-family:'Pokemon GB',monospace;">chat</button>
                        <button onclick="quickTest('how do i get a digimon?')" style="background:#333;color:#F0B088;border:1px solid #F0B088;padding:3px 8px;font-size:9px;cursor:pointer;font-family:'Pokemon GB',monospace;">how to get</button>
                    </div>

                    <!-- Test Result -->
                    <div id="test-result" style="display:none; background:#0a0a0a; border:2px solid #333; padding:12px; margin-top:10px;">
                        <div style="color:#48A058; font-size:10px; margin-bottom:5px;">AGENT RESPONSE:</div>
                        <div style="color:#F0B088; font-size:9px; margin-bottom:5px;">Command: <span id="test-result-command"></span></div>
                        <div id="test-result-text" style="color:#F8F3F8; font-size:10px; line-height:1.6; word-break:break-word; white-space:pre-wrap;"></div>
                        <div id="test-result-image-container" style="display:none; margin-top:10px; text-align:center;">
                            <img id="test-result-image" style="max-width:100%; border:2px solid #48A058; image-rendering:pixelated;">
                        </div>
                    </div>
                </div>

                <!-- Recent Replies Log -->
                <div style="background:#181010; border:3px solid #48A058; padding:15px;">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                        <span style="color:#48A058; font-size:11px;">RECENT REPLY LOG</span>
                        <button onclick="loadRecentReplies()" class="btn-secondary" style="font-size:9px;">RELOAD</button>
                    </div>
                    <div id="replies-log" style="max-height:400px; overflow-y:auto; font-size:9px; color:#F8F3F8;">
                        <div style="color:#888;">Loading...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Pet Modal -->
    <div id="edit-modal" class="fixed inset-0 bg-black bg-opacity-50 modal hidden z-50">
        <div class="flex items-center justify-center min-h-screen p-4">
            <div class="admin-card rounded-lg p-6 w-full max-w-2xl">
                <h3 class="text-xl font-bold mb-4">✏️ Edit Pet</h3>
                <form id="edit-pet-form" class="space-y-4">
                    <input type="hidden" id="edit-pet-id">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium mb-2">ASCII Art</label>
                            <textarea id="edit-pet-ascii" rows="8" class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white font-mono text-sm"></textarea>
                        </div>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium mb-2">Name</label>
                                <input type="text" id="edit-pet-name" class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white">
                            </div>
                            <div>
                                <label class="block text-sm font-medium mb-2">Type</label>
                                <input type="text" id="edit-pet-race" class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white">
                            </div>
                            <div>
                                <label class="block text-sm font-medium mb-2">Owner X Link</label>
                                <input type="url" id="edit-pet-owner" class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white">
                            </div>
                            <div>
                                <label class="block text-sm font-medium mb-2">Status</label>
                                <select id="edit-pet-status" class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white">
                                    <option value="Happy">😊 Happy</option>
                                    <option value="Sleepy">😴 Sleepy</option>
                                    <option value="Excited">🤩 Excited</option>
                                    <option value="Calm">😌 Calm</option>
                                    <option value="Playful">🎮 Playful</option>
