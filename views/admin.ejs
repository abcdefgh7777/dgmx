                    <div class="flex gap-2">
                        <button type="submit" class="bg-blue-600 hover:bg-blue-700 px-6 py-2 rounded transition duration-300">
                            💾 Save Changes
                        </button>
                        <button type="button" onclick="closeEditModal()" class="bg-gray-600 hover:bg-gray-700 px-6 py-2 rounded transition duration-300">
                            ❌ Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Feeding Card Generator Modal -->
    <div id="feeding-card-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50">
        <div class="flex items-center justify-center min-h-screen p-4">
            <div class="bg-gray-800 rounded-lg p-6 max-w-lg w-full">
                <h3 class="text-xl font-bold mb-4">⚡ DIGIMON X Power-up Update</h3>
                
                <div class="mb-4">
                    <canvas id="feeding-canvas" width="800" height="600" style="max-width: 100%; border: 1px solid #666;"></canvas>
                </div>
                
                <div class="flex gap-2">
                    <button onclick="downloadFeedingCard()" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded transition duration-300">
                        💾 Download Image
                    </button>
                    <button onclick="copyFeedingCard()" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded transition duration-300">
                        📋 Copy to Clipboard
                    </button>
                    <button onclick="closeFeedingCard()" class="bg-gray-600 hover:bg-gray-700 px-4 py-2 rounded transition duration-300">
                        ❌ Close
                    </button>
                </div>
                
                <div class="mt-4 p-3 bg-gray-700 rounded text-sm">
                    <p class="text-green-400">⚡ Share your Digimon's power-up moments on social media!</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Status Card Generator Modal -->
    <div id="status-card-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50">
        <div class="flex items-center justify-center min-h-screen p-4">
            <div class="bg-gray-800 rounded-lg p-6 max-w-lg w-full">
                <h3 class="text-xl font-bold mb-4">📊 DIGIMON X Status</h3>
                
                <div class="mb-4">
                    <canvas id="status-canvas" width="800" height="600" style="max-width: 100%; border: 1px solid #666;"></canvas>
                </div>
                
                <div class="flex gap-2">
                    <button onclick="downloadStatusCard()" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded transition duration-300">
                        💾 Download Image
                    </button>
                    <button onclick="copyStatusCard()" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded transition duration-300">
                        📋 Copy to Clipboard
                    </button>
                    <button onclick="closeStatusCard()" class="bg-gray-600 hover:bg-gray-700 px-4 py-2 rounded transition duration-300">
                        ❌ Close
                    </button>
                </div>
                
                <div class="mt-4 p-3 bg-gray-700 rounded text-sm">
                    <p class="text-cyan-400">📊 Share your Digimon's complete status with others!</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentGeneratedPet = null;

        // Tab switching
        function showTab(tabName) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.add('hidden');
            });
            
            // Remove active class from all buttons
            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
                btn.classList.add('bg-gray-700', 'hover:bg-gray-600');
            });
            
            // Show selected tab and activate button
            document.getElementById(tabName + '-content').classList.remove('hidden');
            const activeBtn = document.getElementById(tabName + '-tab');
            activeBtn.classList.add('active');
            activeBtn.classList.remove('bg-gray-700', 'hover:bg-gray-600');
        }

        // Add pet form submission
        document.getElementById('add-pet-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const petData = {
                ascii: document.getElementById('pet-ascii').value,
                name: document.getElementById('pet-name').value,
                race: document.getElementById('pet-race').value,
                owner: document.getElementById('pet-owner').value,
                status: document.getElementById('pet-status').value
            };
            
            if (!petData.ascii || !petData.name || !petData.race || !petData.owner) {
                alert('Please fill in all fields');
                return;
            }
            
            try {
                const response = await fetch('/api/pets', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(petData)
                });
                
                const result = await response.json();
                if (result.success) {
                    alert('Pet added successfully!');
                    location.reload();
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (error) {
                alert('Error adding pet: ' + error.message);
            }
        });

        // Feed pet
        async function feedPet(petId) {
            try {
                const response = await fetch(`/api/pets/${petId}/feed`, {
                    method: 'POST'
                });
                
                const result = await response.json();
                console.log('Feed result:', result); // Debug log
                
                if (result.success) {
                    // Generate feeding card
                    console.log('Generating feeding card...'); // Debug log
                    generateFeedingCard(result.pet, result.feedingMessage);
                } else {
                    // Generate cooldown card
                    console.log('Generating cooldown card...'); // Debug log
                    generateCooldownCard(result.pet, result.cooldownMinutes);
                }
            } catch (error) {
                console.error('Feed error:', error); // Debug log
                alert('Error feeding pet: ' + error.message);
            }
        }

        // Delete pet
        async function deletePet(petId) {
            if (!confirm('Are you sure you want to delete this pet?')) return;
            
            try {
                const response = await fetch(`/api/pets/${petId}`, {
                    method: 'DELETE'
                });
                
                const result = await response.json();
                if (result.success) {
                    alert('Pet deleted successfully!');
                    location.reload();
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (error) {
                alert('Error deleting pet: ' + error.message);
            }
        }

        // Edit pet
        async function editPet(petId) {
            try {
                const response = await fetch(`/api/pets/${petId}`);
                const result = await response.json();
                
                if (result.success) {
                    const pet = result.pet;
                    document.getElementById('edit-pet-id').value = pet.id;
                    document.getElementById('edit-pet-ascii').value = pet.ascii;
                    document.getElementById('edit-pet-name').value = pet.name;
                    document.getElementById('edit-pet-race').value = pet.race;
                    document.getElementById('edit-pet-owner').value = pet.owner;
                    document.getElementById('edit-pet-status').value = pet.status;
                    
                    document.getElementById('edit-modal').classList.remove('hidden');
                } else {
                    alert('Error loading pet: ' + result.error);
                }
            } catch (error) {
                alert('Error loading pet: ' + error.message);
            }
        }

        // Use template
        async function useTemplate(templateId) {
            try {
                const response = await fetch(`/api/templates/${templateId}`);
                const result = await response.json();
                
                if (result.success) {
                    const template = result.template;
                    document.getElementById('pet-ascii').value = template.ascii;
                    document.getElementById('pet-name').value = template.name;
                    document.getElementById('pet-race').value = template.race;
                    
                    // Switch to add pet tab
                    showTab('add-pet');
                    alert(`Template "${template.name}" loaded! Please add owner link and adjust as needed.`);
                } else {
                    alert('Error loading template: ' + result.error);
                }
            } catch (error) {
                alert('Error loading template: ' + error.message);
            }
        }

        // Catch Pokemon
        async function captureDigimon() {
            const ownerInput = document.getElementById('ai-owner');
            if (!ownerInput.value) {
                alert('Please enter a tamer X link');
                return;
            }
            
            const button = event.target;
            button.disabled = true;
            button.textContent = '⚡ Entering Digital World...';
            
            try {
                const response = await fetch('/api/capture-digimon', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ownerLink: ownerInput.value })
                });
                
                const result = await response.json();
                
                if (result.success && result.type === 'catch_success') {
                    // Success - Digimon captured!
                    currentGeneratedPet = result.digimon;
                    
                    // Show Digimon GIF if available, otherwise fallback to ASCII
                    if (result.digimon.gifPath) {
                        document.getElementById('ai-gif-container').style.display = 'flex';
                        document.getElementById('ai-gif').src = result.digimon.gifPath;
                        document.getElementById('ai-ascii').style.display = 'none';
                    } else {
                        document.getElementById('ai-ascii').textContent = result.digimon.ascii || 'No preview available';
                        document.getElementById('ai-ascii').style.display = 'block';
                        document.getElementById('ai-gif-container').style.display = 'none';
                    }
                    
                    document.getElementById('ai-name').textContent = result.digimon.name;
                    document.getElementById('ai-race').textContent = result.digimon.element + ' - ' + result.digimon.level;
                    document.getElementById('ai-owner-display').textContent = ownerInput.value;
                    document.getElementById('ai-preview').classList.remove('hidden');
                    
                    // Generate success card
                    generateCatchSuccessCard(result.digimon, ownerInput.value);
                } else if (result.type === 'catch_failed') {
                    // Failed to catch
                    generateCatchFailureCard(ownerInput.value);
                } else if (result.type === 'limit_reached') {
                    // Pokemon limit reached - generate limit card
                    generateMaxLimitCard(ownerInput.value);
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (error) {
                alert('Error capturing Digimon: ' + error.message);
            } finally {
                button.disabled = false;
                button.textContent = '⚡ Enter Digital World!';
            }
        }

        function acceptGenerated() {
            if (!currentGeneratedPet) return;
            
            // Since the Digimon is already saved to the database, just generate the social card
            if (confirm('🎉 Digimon captured and saved! Would you like to generate a social media card to share on X/Twitter?')) {
                generateSocialCard();
            } else {
                hidePreview();
                // Refresh the page to show the new Digimon in the collection
                location.reload();
            }
        }

        function hidePreview() {
            document.getElementById('ai-preview').classList.add('hidden');
            currentGeneratedPet = null;
        }

        // Generate Social Media Card
        function generateSocialCard() {
            if (!currentGeneratedPet) return;
            
            const canvas = document.getElementById('social-canvas');
            const ctx = canvas.getContext('2d');
            
            // Load background image
            const bgImg = new Image();
            bgImg.onload = function() {
                // Draw background
                ctx.drawImage(bgImg, 0, 0, 800, 600);
                
                // Add dark overlay for better text readability
                ctx.fillStyle = 'rgba(0, 0, 0, 0.6)';
                ctx.fillRect(0, 0, 800, 600);
                
                // Title
                ctx.fillStyle = '#ffffff';
                ctx.font = 'bold 28px "Courier New", "Monaco", "Menlo", monospace';
                ctx.textAlign = 'center';
                ctx.fillText('DIGIVICE CONNECTED!', 400, 80);
                
                // Load Pokemon image
                loadSocialPokemonImage();
            };
            bgImg.src = '/card.png';
            
            function loadSocialPokemonImage() {
            
                // Load and draw Pokemon GIF (as static image)
                if (currentGeneratedPet.gifPath) {
                    const img = new Image();
                    img.onload = function() {
                        // Draw Pokemon image in center (no background)
                        const imgSize = 150;
                        const imgX = 400 - imgSize/2;
                        const imgY = 120;
                        
                        ctx.drawImage(img, imgX, imgY, imgSize, imgSize);
                        
                        // Continue with text after image loads
                        drawSocialCardText();
                    };
                    img.src = currentGeneratedPet.gifPath;
                } else {
                    // No image, just draw text
                    drawSocialCardText();
                }
            }
            
            function drawSocialCardText() {
                // Pokemon info display (moved down to make room for image)
                ctx.fillStyle = '#ffffff';
                ctx.font = 'bold 20px "Courier New", "Monaco", "Menlo", monospace';
                ctx.textAlign = 'center';
                
                const startY = 300;
                ctx.fillText(currentGeneratedPet.name, 400, startY);
                
                ctx.fillStyle = '#00ffff';
                ctx.font = '16px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText(`Type: ${currentGeneratedPet.element}`, 400, startY + 40);
                
                // Trainer info
                const ownerHandle = document.getElementById('ai-owner').value.match(/(?:twitter\.com\/|x\.com\/)([^\/\?]+)/);
                const username = ownerHandle ? `@${ownerHandle[1]}` : '@tamer';
                
                ctx.fillStyle = '#888888';
                ctx.font = '14px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText(`Tamer: ${username}`, 400, startY + 80);
            }
            
            // Show modal
            document.getElementById('social-card-modal').classList.remove('hidden');
        }
        
        function downloadSocialCard() {
            const canvas = document.getElementById('social-canvas');
            const link = document.createElement('a');
            link.download = `poketto-${currentGeneratedPet.name.toLowerCase()}-caught.png`;
            link.href = canvas.toDataURL();
            link.click();
        }
        
        function copySocialCard() {
            const canvas = document.getElementById('social-canvas');
            canvas.toBlob(function(blob) {
                const item = new ClipboardItem({ 'image/png': blob });
                navigator.clipboard.write([item]).then(function() {
                    alert('✅ Image copied to clipboard! You can now paste it on X/Twitter.');
                }).catch(function(err) {
                    console.error('Failed to copy image: ', err);
                    alert('❌ Failed to copy image. Try downloading instead.');
                });
            });
        }
        
        function closeSocialCard() {
            document.getElementById('social-card-modal').classList.add('hidden');
        }

        // Generate Catch Success Card
        function generateCatchSuccessCard(digimon, trainerLink) {
            const canvas = document.getElementById('social-canvas');
            const ctx = canvas.getContext('2d');
            
            // Load background image
            const bgImg = new Image();
            bgImg.onload = function() {
                // Draw background
                ctx.drawImage(bgImg, 0, 0, 800, 600);
                
                // Add dark overlay for better text readability
                ctx.fillStyle = 'rgba(0, 0, 0, 0.6)';
                ctx.fillRect(0, 0, 800, 600);
                
                // Title
                ctx.fillStyle = '#ffffff';
                ctx.font = 'bold 28px "Courier New", "Monaco", "Menlo", monospace';
                ctx.textAlign = 'center';
                ctx.fillText('DIGIVICE SYNCHRONIZED!', 400, 80);
                
                // Success message
                ctx.fillStyle = '#00ffff';
                ctx.font = '16px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText('Congratulations, Tamer!', 400, 110);
                
                // Load Digimon GIF after background loads
                loadDigimonImage();
            };
            bgImg.src = '/card.png';
            
            function loadDigimonImage() {
            
                // Load and draw Digimon GIF (as static image)
                if (digimon.gifPath) {
                    const img = new Image();
                    img.onload = function() {
                        // Draw Digimon image in center (no background)
                        const imgSize = 150;
                        const imgX = 400 - imgSize/2;
                        const imgY = 140;
                        
                        ctx.drawImage(img, imgX, imgY, imgSize, imgSize);
                        
                        // Continue with text after image loads
                        drawSuccessCardText();
                    };
                    img.src = digimon.gifPath;
                } else {
                    // No image, just draw text
                    drawSuccessCardText();
                }
            }
            
            function drawSuccessCardText() {
                // Digimon caught display
                ctx.fillStyle = '#ffffff';
                ctx.font = 'bold 20px "Courier New", "Monaco", "Menlo", monospace';
                ctx.textAlign = 'center';
                
                // Show caught Digimon info (moved down to make room for image)
                const startY = 320;
                ctx.fillText(`${digimon.name} partnered with you!`, 400, startY);
                
                ctx.fillStyle = '#00ffff';
                ctx.font = '16px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText(`Type: ${digimon.element}`, 400, startY + 40);
                
                // Trainer info
                const ownerHandle = trainerLink.match(/(?:twitter\.com\/|x\.com\/)([^\/\?]+)/);
                const username = ownerHandle ? `@${ownerHandle[1]}` : '@tamer';
                
                ctx.fillStyle = '#888888';
                ctx.font = '14px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText(`Tamer: ${username}`, 400, startY + 80);
            }
            
            // Show modal
            document.getElementById('social-card-modal').classList.remove('hidden');
        }

        // Generate Max Pokemon Limit Card
        function generateMaxLimitCard(trainerLink) {
            const canvas = document.getElementById('social-canvas');
            const ctx = canvas.getContext('2d');
            
            // Load background image
            const bgImg = new Image();
            bgImg.onload = function() {
                // Draw background
                ctx.drawImage(bgImg, 0, 0, 800, 600);
                
                // Add dark overlay for better text readability
                ctx.fillStyle = 'rgba(0, 0, 0, 0.6)';
                ctx.fillRect(0, 0, 800, 600);
                
                // Title
                ctx.fillStyle = '#ffaa00';
                ctx.font = 'bold 24px "Courier New", "Monaco", "Menlo", monospace';
                ctx.textAlign = 'center';
                ctx.fillText('DIGIMON LIMIT REACHED!', 400, 80);
                
                drawLimitContent();
            };
            bgImg.src = '/card.png';
            
            function drawLimitContent() {
            
                // Warning message
                ctx.fillStyle = '#ffffff';
                ctx.font = '16px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText('Maximum 3 Digimon per tamer', 400, 120);
                
                // Main message
                ctx.fillStyle = '#00ffff';
                ctx.font = 'bold 18px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText('Your team is complete!', 400, 280);
                
                // Instructions message
                ctx.fillStyle = '#ffaa00';
                ctx.font = '14px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText('Release a Digimon to capture new ones', 400, 320);
                
                // Trainer info
                const ownerHandle = trainerLink.match(/(?:twitter\.com\/|x\.com\/)([^\/\?]+)/);
                const username = ownerHandle ? `@${ownerHandle[1]}` : '@tamer';
                
                ctx.fillStyle = '#888888';
                ctx.font = '14px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText(`Trainer: ${username}`, 400, 370);
            }
            
            // Show modal
            document.getElementById('social-card-modal').classList.remove('hidden');
        }

        // Generate Catch Failure Card
        function generateCatchFailureCard(trainerLink) {
            const canvas = document.getElementById('social-canvas');
            const ctx = canvas.getContext('2d');
            
            // Load background image
            const bgImg = new Image();
            bgImg.onload = function() {
                // Draw background
                ctx.drawImage(bgImg, 0, 0, 800, 600);
                
                // Add dark overlay for better text readability
                ctx.fillStyle = 'rgba(0, 0, 0, 0.6)';
                ctx.fillRect(0, 0, 800, 600);
                
                // Title
                ctx.fillStyle = '#ff6666';
                ctx.font = 'bold 26px "Courier New", "Monaco", "Menlo", monospace';
                ctx.textAlign = 'center';
                ctx.fillText('CAPTURE FAILED!', 400, 80);
                
                drawFailureContent();
            };
            bgImg.src = '/card.png';
            
            function drawFailureContent() {
            
                // Failure message
                ctx.fillStyle = '#ffffff';
                ctx.font = '16px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText('The Digimon escaped!', 400, 120);
                
                // Main message
                ctx.fillStyle = '#00ffff';
                ctx.font = 'bold 18px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText('Better luck next time, Tamer!', 400, 300);
                
                // Trainer info
                const ownerHandle = trainerLink.match(/(?:twitter\.com\/|x\.com\/)([^\/\?]+)/);
                const username = ownerHandle ? `@${ownerHandle[1]}` : '@tamer';
                
                ctx.fillStyle = '#888888';
                ctx.font = '14px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText(`Trainer: ${username}`, 400, 350);
            }
            
            // Show modal
            document.getElementById('social-card-modal').classList.remove('hidden');
        }
        
        // Generate Feeding Card
        function generateFeedingCard(pet, feedingMessage) {
            console.log('generateFeedingCard called with:', pet, feedingMessage); // Debug log
            const canvas = document.getElementById('feeding-canvas');
            const ctx = canvas.getContext('2d');
            console.log('Canvas found:', canvas); // Debug log
            
            // Clear canvas
            ctx.fillStyle = '#15161B';
            ctx.fillRect(0, 0, 800, 600);
            
            // Draw terminal-style border
            ctx.strokeStyle = '#00ff00';
            ctx.lineWidth = 2;
            ctx.strokeRect(20, 20, 760, 560);
            
            // Draw inner border
            ctx.strokeStyle = '#333333';
            ctx.lineWidth = 1;
            ctx.strokeRect(40, 40, 720, 520);
            
            // Set font for monospace text
            ctx.font = '28px "JetBrains Mono", "Courier New", monospace';
            ctx.textAlign = 'center';
            
            // Title
            ctx.fillStyle = '#00ff00';
            ctx.font = 'bold 30px "JetBrains Mono", monospace';
            ctx.fillText('DIGIMON X Feeding Time!', 400, 90);
            
            // Terminal prompt style
            ctx.fillStyle = '#ffffff';
            ctx.font = '16px "JetBrains Mono", monospace';
            ctx.textAlign = 'left';
            ctx.fillText('$ digimon-x --feed-digimon --id=' + pet.id, 60, 120);
            
            // Pokemon info display (no ASCII)
            ctx.fillStyle = '#00ffff';
            ctx.font = '24px "JetBrains Mono", monospace';
            ctx.textAlign = 'center';
            
            const startY = 160;
            ctx.fillText(`🔋 ${pet.name} Power-up Time! 🔋`, 400, startY);
            
            ctx.fillStyle = '#ffff00';
            ctx.font = '20px "JetBrains Mono", monospace';
            ctx.fillText(`Type: ${pet.race}`, 400, startY + 40);
            
            // Pet Name
            ctx.fillStyle = '#ffffff';
            ctx.font = 'bold 26px "JetBrains Mono", monospace';
            const petInfoY = startY + 80;
            ctx.fillText(pet.name, 400, petInfoY);
            
            // Feeding Message (word wrap)
            ctx.fillStyle = '#ffff00';
            ctx.font = '16px "JetBrains Mono", monospace';
            ctx.textAlign = 'center';
            
            const words = feedingMessage.split(' ');
            let line = '';
            let y = petInfoY + 50;
            
            for (let n = 0; n < words.length; n++) {
                const testLine = line + words[n] + ' ';
                const metrics = ctx.measureText(testLine);
                const testWidth = metrics.width;
                
                if (testWidth > 680 && n > 0) {
                    ctx.fillText(line, 400, y);
                    line = words[n] + ' ';
                    y += 25;
                } else {
                    line = testLine;
                }
            }
            ctx.fillText(line, 400, y);
            
            // Status line
            ctx.fillStyle = '#00ff00';
            ctx.font = '14px "JetBrains Mono", monospace';
            ctx.textAlign = 'left';
            ctx.fillText('Status: [POWERED] - Digimon successfully powered up! Power count: ' + pet.feed_count + ' | Level: ' + pet.growth_stage, 60, 520);
            
            // Bottom branding
            ctx.fillStyle = '#333333';
            ctx.font = '12px "JetBrains Mono", monospace';
            ctx.textAlign = 'right';
            ctx.fillText('DIGIMON-X.system v2.0', 740, 550);
            
            // Show modal
            console.log('Showing feeding card modal...'); // Debug log
            const modal = document.getElementById('feeding-card-modal');
            console.log('Modal element:', modal); // Debug log
            modal.classList.remove('hidden');
            modal.style.display = 'flex'; // Force display
            modal.style.zIndex = '9999'; // Force z-index
            console.log('Modal classes after show:', modal.className); // Debug log
            console.log('Modal style after show:', modal.style.cssText); // Debug log
        }
        
        // Generate Cooldown Card
        function generateCooldownCard(pet, cooldownMinutes) {
            const canvas = document.getElementById('feeding-canvas');
            const ctx = canvas.getContext('2d');
            
            // Clear canvas - same setup as feeding card
            ctx.fillStyle = '#15161B';
            ctx.fillRect(0, 0, 800, 600);
            
            // Draw terminal-style borders
            ctx.strokeStyle = '#ff6666';
            ctx.lineWidth = 2;
            ctx.strokeRect(20, 20, 760, 560);
            
            ctx.strokeStyle = '#333333';
            ctx.lineWidth = 1;
            ctx.strokeRect(40, 40, 720, 520);
            
            // Title
            ctx.fillStyle = '#ff6666';
            ctx.font = 'bold 30px "JetBrains Mono", monospace';
            ctx.textAlign = 'center';
            ctx.fillText('DIGIMON X - Already Powered!', 400, 90);
            
            // Terminal prompt
            ctx.fillStyle = '#ffffff';
            ctx.font = '16px "JetBrains Mono", monospace';
            ctx.textAlign = 'left';
            ctx.fillText('$ digimon-x --feed-digimon --id=' + pet.id, 60, 120);
            
            // Pokemon info display (no ASCII)
            ctx.fillStyle = '#888888';
            ctx.font = '24px "JetBrains Mono", monospace';
            ctx.textAlign = 'center';
            
            const startY = 160;
            ctx.fillText(`⚡ ${pet.name} is Fully Charged! ⚡`, 400, startY);
            
            ctx.fillStyle = '#ffff00';
            ctx.font = '20px "JetBrains Mono", monospace';
            ctx.fillText(`Type: ${pet.race}`, 400, startY + 40);
            
            // Pet Name
            ctx.fillStyle = '#ffffff';
            ctx.font = 'bold 26px "JetBrains Mono", monospace';
            const petInfoY = startY + 80;
            ctx.fillText(pet.name, 400, petInfoY);
            
            // Cooldown Message
            ctx.fillStyle = '#ffff00';
            ctx.font = '20px "JetBrains Mono", monospace';
            ctx.fillText('"My power is at maximum! ⚡"', 400, petInfoY + 50);
            
            ctx.fillStyle = '#ff6666';
            ctx.font = '18px "JetBrains Mono", monospace';
            ctx.fillText('Please come back in ' + cooldownMinutes + ' minutes', 400, petInfoY + 85);
            
            // Status line
            ctx.fillStyle = '#ff6666';
            ctx.font = '14px "JetBrains Mono", monospace';
            ctx.textAlign = 'left';
            ctx.fillText('Status: [COOLDOWN] - Digimon power recharging | Next power-up in: ' + cooldownMinutes + 'min', 60, 520);
            
            // Bottom branding
            ctx.fillStyle = '#333333';
            ctx.font = '12px "JetBrains Mono", monospace';
            ctx.textAlign = 'right';
            ctx.fillText('DIGIMON-X.system v2.0', 740, 550);
            
            // Show modal
            console.log('Showing feeding card modal...'); // Debug log
            const modal = document.getElementById('feeding-card-modal');
            console.log('Modal element:', modal); // Debug log
            modal.classList.remove('hidden');
            modal.style.display = 'flex'; // Force display
            modal.style.zIndex = '9999'; // Force z-index
            console.log('Modal classes after show:', modal.className); // Debug log
            console.log('Modal style after show:', modal.style.cssText); // Debug log
        }
        
        function downloadFeedingCard() {
            const canvas = document.getElementById('feeding-canvas');
            const link = document.createElement('a');
            const timestamp = new Date().toISOString().slice(0, 16).replace(/[:T]/g, '-');
            link.download = `poketto-feeding-${timestamp}.png`;
            link.href = canvas.toDataURL();
            link.click();
        }
        
        function copyFeedingCard() {
            const canvas = document.getElementById('feeding-canvas');
            canvas.toBlob(function(blob) {
                const item = new ClipboardItem({ 'image/png': blob });
                navigator.clipboard.write([item]).then(function() {
                    alert('✅ Power-up card copied to clipboard!');
                }).catch(function(err) {
                    console.error('Failed to copy image: ', err);
                    alert('❌ Failed to copy image. Try downloading instead.');
                });
            });
        }
        
        function closeFeedingCard() {
            const modal = document.getElementById('feeding-card-modal');
            modal.classList.add('hidden');
            modal.style.display = ''; // Reset display
            modal.style.zIndex = ''; // Reset z-index
        }

        // Generate Status Card
        async function generateStatusCard(petId) {
            try {
                const response = await fetch(`/api/pets/${petId}`);
                const result = await response.json();
                
                if (result.success) {
                    const pet = result.pet;
                    createStatusCard(pet);
                } else {
                    alert('Error loading pet: ' + result.error);
                }
            } catch (error) {
                alert('Error loading pet: ' + error.message);
            }
        }

        function createStatusCard(pet) {
            const canvas = document.getElementById('status-canvas');
            const ctx = canvas.getContext('2d');
            
            // Load background image
            const bgImg = new Image();
            bgImg.onload = function() {
                // Draw background
                ctx.drawImage(bgImg, 0, 0, 800, 600);
                
                // Add dark overlay for better text readability
                ctx.fillStyle = 'rgba(0, 0, 0, 0.6)';
                ctx.fillRect(0, 0, 800, 600);
                
                // Title
                ctx.fillStyle = '#ffffff';
                ctx.font = 'bold 22px "Courier New", "Monaco", "Menlo", monospace';
                ctx.textAlign = 'center';
                ctx.fillText('Digimon Status', 400, 60);
                
                loadStatusPokemonImage();
            };
            bgImg.src = '/card.png';
            
            function loadStatusPokemonImage() {
            
                // Load and draw Pokemon GIF (as static image) if available
                if (pet.ascii && pet.ascii.startsWith('/digimon/')) {
                    const img = new Image();
                    img.onload = function() {
                        // Draw Pokemon image in center (no background)
                        const imgSize = 120;
                        const imgX = 400 - imgSize/2;
                        const imgY = 100;
                        
                        ctx.drawImage(img, imgX, imgY, imgSize, imgSize);
                        
                        // Continue with text after image loads
                        drawStatusCardText();
                    };
                    img.src = pet.ascii;
                } else {
                    // No image, just draw text
                    drawStatusCardText();
                }
            }
            
            function drawStatusCardText() {
                // Pokemon info display (moved down to make room for image)
                ctx.fillStyle = '#ffffff';
                ctx.font = 'bold 20px "Courier New", "Monaco", "Menlo", monospace';
                ctx.textAlign = 'center';
                
                const startY = pet.ascii && pet.ascii.startsWith('/digimon/') ? 240 : 100;
                ctx.fillText(pet.name, 400, startY);
                
                ctx.fillStyle = '#00ffff';
                ctx.font = '16px "Courier New", "Monaco", "Menlo", monospace';
                ctx.fillText(`Type: ${pet.race}`, 400, startY + 30);
            
                // Status Information
                ctx.textAlign = 'center';
                ctx.fillStyle = '#888888';
                ctx.font = '14px "Courier New", "Monaco", "Menlo", monospace';
                
                const statusY = startY + 80;
                ctx.fillText(`Growth: ${pet.growth_stage}`, 400, statusY);
                ctx.fillText(`Fed: ${pet.feed_count} times`, 400, statusY + 25);
                
                // Owner info
                const ownerHandle = pet.ownerHandle || 'Unknown Tamer';
                ctx.fillText(`Trainer: ${ownerHandle}`, 400, statusY + 50);
            }
            
            // Show modal
            document.getElementById('status-card-modal').classList.remove('hidden');
        }
        
        function downloadStatusCard() {
            const canvas = document.getElementById('status-canvas');
            const link = document.createElement('a');
            const timestamp = new Date().toISOString().slice(0, 16).replace(/[:T]/g, '-');
            link.download = `digimon-x-status-${timestamp}.png`;
            link.href = canvas.toDataURL();
            link.click();
        }
        
        function copyStatusCard() {
            const canvas = document.getElementById('status-canvas');
            canvas.toBlob(function(blob) {
                const item = new ClipboardItem({ 'image/png': blob });
                navigator.clipboard.write([item]).then(function() {
                    alert('✅ Status card copied to clipboard!');
                }).catch(function(err) {
                    console.error('Failed to copy image: ', err);
                    alert('❌ Failed to copy image. Try downloading instead.');
                });
            });
        }
        
        function closeStatusCard() {
            document.getElementById('status-card-modal').classList.add('hidden');
        }

        // Edit pet form submission
        document.getElementById('edit-pet-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const petId = document.getElementById('edit-pet-id').value;
            const petData = {
                ascii: document.getElementById('edit-pet-ascii').value,
                name: document.getElementById('edit-pet-name').value,
                race: document.getElementById('edit-pet-race').value,
                owner: document.getElementById('edit-pet-owner').value,
                status: document.getElementById('edit-pet-status').value
            };
            
            if (!petData.ascii || !petData.name || !petData.race || !petData.owner) {
                alert('Please fill in all fields');
                return;
            }
            
            try {
                const response = await fetch(`/api/pets/${petId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(petData)
                });
                
                const result = await response.json();
                if (result.success) {
                    alert('Pet updated successfully!');
                    closeEditModal();
                    location.reload();
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (error) {
                alert('Error updating pet: ' + error.message);
            }
        });

        function closeEditModal() {
            document.getElementById('edit-modal').classList.add('hidden');
        }

        // ── X Agent Functions ──
        async function refreshAgentStatus() {
            try {
                const res = await fetch('/api/admin/agent/status');
                const data = await res.json();
                const badge = document.getElementById('agent-status-badge');
                if (data.active) {
                    badge.textContent = 'ONLINE';
                    badge.style.background = '#48A058';
                } else {
                    badge.textContent = 'OFFLINE';
                    badge.style.background = '#B3181C';
                }
                document.getElementById('agent-bot-name').textContent = data.botUsername || 'digimononx';
                document.getElementById('agent-replies-today').textContent = data.stats?.repliesToday || 0;
                document.getElementById('agent-replies-total').textContent = data.stats?.repliesTotal || 0;
                document.getElementById('agent-last-checked').textContent = data.stats?.lastChecked ? new Date(data.stats.lastChecked).toLocaleString() : 'never';
                document.getElementById('agent-last-error').textContent = data.stats?.lastError || 'none';
            } catch (e) {
                console.error('Status error:', e);
            }
        }

        async function startAgent() {
            try {
                const res = await fetch('/api/admin/agent/start', { method: 'POST' });
                const data = await res.json();
                alert(data.message || data.error || 'Agent started');
                refreshAgentStatus();
            } catch (e) { alert('Error: ' + e.message); }
        }

        async function stopAgent() {
            try {
                const res = await fetch('/api/admin/agent/stop', { method: 'POST' });
                const data = await res.json();
                alert(data.message || data.error || 'Agent stopped');
                refreshAgentStatus();
            } catch (e) { alert('Error: ' + e.message); }
        }

        async function clearReplies() {
            if (!confirm('Clear all reply logs?')) return;
            try {
                await fetch('/api/admin/agent/clear-replies', { method: 'POST' });
                loadRecentReplies();
            } catch (e) { alert('Error: ' + e.message); }
        }

        async function clearFailed() {
            try {
                const res = await fetch('/api/admin/agent/clear-failed', { method: 'POST' });
                const data = await res.json();
                alert('Cleared ' + (data.cleared || 0) + ' failed replies');
            } catch (e) { alert('Error: ' + e.message); }
        }

        async function backfillAvatars() {
            try {
                const res = await fetch('/api/admin/agent/backfill-avatars', { method: 'POST' });
                const data = await res.json();
                alert(data.message || 'Done');
            } catch (e) { alert('Error: ' + e.message); }
        }

        async function testAgentReply() {
            const username = document.getElementById('test-username').value.replace('@', '') || 'testuser';
            const message = document.getElementById('test-message').value;
            if (!message) { alert('Enter a message to test'); return; }

            const resultDiv = document.getElementById('test-result');
            resultDiv.style.display = 'block';
            document.getElementById('test-result-text').textContent = 'Processing...';
            document.getElementById('test-result-command').textContent = '...';
            document.getElementById('test-result-image-container').style.display = 'none';

            try {
                const res = await fetch('/api/admin/agent/test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, message })
                });
                const data = await res.json();

                if (data.ok) {
                    document.getElementById('test-result-command').textContent = data.command || 'unknown';
                    document.getElementById('test-result-text').textContent = data.text || '(no text)';
                    if (data.image) {
                        document.getElementById('test-result-image').src = data.image;
                        document.getElementById('test-result-image-container').style.display = 'block';
                    }
                } else {
                    document.getElementById('test-result-text').textContent = 'ERROR: ' + (data.error || 'Unknown error');
                }
            } catch (e) {
                document.getElementById('test-result-text').textContent = 'ERROR: ' + e.message;
            }
        }

        function quickTest(msg) {
            document.getElementById('test-message').value = msg;
            testAgentReply();
        }

        async function loadRecentReplies() {
            try {
                const res = await fetch('/api/admin/agent/replies?limit=30');
                const data = await res.json();
                const container = document.getElementById('replies-log');

                if (!data.replies || data.replies.length === 0) {
                    container.innerHTML = '<div style="color:#888;">No replies yet</div>';
                    return;
                }

                container.innerHTML = data.replies.map(r => {
                    const time = r.created_at ? new Date(r.created_at).toLocaleString() : '?';
                    const status = r.status === 'replied' ? '<span style="color:#48A058;">OK</span>' : '<span style="color:#B3181C;">' + (r.status || 'pending') + '</span>';
                    return '<div style="border-bottom:1px solid #222; padding:6px 0;">' +
                        '<div style="color:#F0B088;">@' + (r.author_username || '?') + ' ' + status + ' <span style="color:#555;">' + time + '</span></div>' +
                        '<div style="color:#888; margin:2px 0;">' + (r.tweet_text || '').substring(0, 100) + '</div>' +
                        '<div style="color:#48A058;">' + (r.our_reply || '').substring(0, 150) + '</div>' +
                    '</div>';
                }).join('');
            } catch (e) {
                document.getElementById('replies-log').innerHTML = '<div style="color:#B3181C;">Error loading replies</div>';
            }
        }

        // Auto-load agent status when X Agent tab is shown
        const origShowTab = showTab;
        showTab = function(tabName) {
            origShowTab(tabName);
            if (tabName === 'x-agent') {
                refreshAgentStatus();
                loadRecentReplies();
            }
        };
    </script>
</body>
</html>