<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DGMX - Nothing to see here</title>
    <link rel="icon" type="image/png" href="/fav.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #0a0e1a;
            color: #00ff00;
            font-family: 'JetBrains Mono', 'Courier New', monospace;
            font-size: 14px;
            line-height: 1.4;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .terminal-login {
            border: 1px solid #1e2a3a;
            background: #0d1117;
            padding: 30px;
            max-width: 460px;
            width: 100%;
            border-radius: 8px;
        }

        .prompt::before {
            content: '$ ';
            color: #ff6600;
        }

        .input-field {
            background: #0a0e1a;
            border: 1px solid #1e2a3a;
            color: #00ff00;
            font-family: 'JetBrains Mono', monospace;
            font-size: 14px;
            padding: 10px;
            width: 100%;
            margin: 10px 0;
            border-radius: 4px;
        }

        .input-field:focus {
            outline: none;
            border-color: #ff6600;
        }

        .btn-terminal {
            background: #1e2a3a;
            border: 1px solid #ff660044;
            color: #ff6600;
            font-family: 'JetBrains Mono', monospace;
            font-size: 14px;
            padding: 10px 20px;
            cursor: pointer;
            transition: all 0.2s ease;
            border-radius: 4px;
        }

        .btn-terminal:hover {
            background: #ff660022;
            border-color: #ff6600;
        }

        .error-msg {
            color: #ff3366;
            margin: 10px 0;
            font-size: 12px;
        }

        .cursor {
            animation: blink 1s infinite;
        }

        @keyframes blink {
            0%, 50% { opacity: 1; }
            51%, 100% { opacity: 0; }
        }
    </style>
</head>
<body>
    <div class="terminal-login">
        <div class="prompt" style="color:#ff6600;">nothing to see here...</div>
        <div style="color: #334455; font-size: 11px; margin: 10px 0;">
            authorized personnel only
        </div>
        <br>

        <form method="POST" action="/admin/login">
            <div style="margin: 15px 0;">
                <input
                    type="password"
                    id="password"
                    name="password"
                    required
                    class="input-field"
                    placeholder="..."
                    autofocus
                >
            </div>

            <% if (error) { %>
                <div class="error-msg">
                    <%= error %>
                </div>
            <% } %>

            <div style="margin: 20px 0;">
                <button type="submit" class="btn-terminal">
                    [ENTER]
                </button>
            </div>
        </form>

        <div style="text-align: center; margin: 15px 0;">
            <a href="/" style="color: #1e2a3a; text-decoration: none; font-size: 11px;">
                go back
            </a>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('password').focus();
        });
        document.getElementById('password').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                this.form.submit();
            }
        });
    </script>
</body>
</html>